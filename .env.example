# ═══════════════════════════════════════════════════════════════
# Yeeyoo Backend — All Environment Variables
# ═══════════════════════════════════════════════════════════════

# ─── SERVER ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://app.yeeyoo.no
BACKEND_URL=https://yeeyoo-backend.onrender.com

# ─── DATABASE ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/yeeyoo

# ─── AUTH ─────────────────────────────────────────────────────
JWT_SECRET=generate-min-32-char-random-string

# ─── GOOGLE OAUTH2 ───────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly
GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-secret
GOOGLE_REDIRECT_URI=https://yeeyoo-backend.onrender.com/api/auth/google/callback

# ─── VIPPS LOGIN ──────────────────────────────────────────────
# Vipps Developer Portal → your application
VIPPS_CLIENT_ID=
VIPPS_CLIENT_SECRET=
VIPPS_SUBSCRIPTION_KEY=
VIPPS_MSN=
VIPPS_REDIRECT_URI=https://yeeyoo-backend.onrender.com/api/auth/vipps/callback
VIPPS_BASE_URL=https://api.vipps.no

# ─── EMAIL (SendGrid) ────────────────────────────────────────
# Used for: email verification, notifications
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=no-reply@yeeyoo.no

# ─── AI MODELS ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
GROK_API_KEY=xai-...
DEEPSEEK_API_KEY=sk-...

# ─── STRIPE BILLING ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_VEKST=price_...
STRIPE_PRICE_BEDRIFT=price_...

# ─── SOCIAL OAUTH (for publishing) ───────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://yeeyoo-backend.onrender.com/api/oauth/linkedin/callback

META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://yeeyoo-backend.onrender.com/api/oauth/meta/callback

TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=https://yeeyoo-backend.onrender.com/api/oauth/twitter/callback

# ─── EMAIL TRACKING (help-tracker) ──────────────────────────
# API key from help-tracker microservice (logged at first startup)
TRACKER_API_KEY=ht_yeeyoo_...
TRACKER_URL=https://help-tracker.onrender.com
